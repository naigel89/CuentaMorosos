<?xml version="1.0" encoding="utf-8"?>
<!--
    Network Security Configuration — CuentaMorosos
    Certificate pinning for Firebase domains with backup pins.
    Pins updated 2026-06-29: Google rotated WR2 intermediate CA key.
-->
<network-security-config>
    <!-- Block all cleartext (HTTP) traffic at platform level -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Firebase Firestore, Auth, Storage API domain -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">googleapis.com</domain>
        <pin-set expiration="2027-06-29">
            <!-- GTS WR2: current intermediate CA for *.googleapis.com -->
            <pin digest="SHA-256">YPtHaftLw6/0vnc2BnNKGF54xiCA28WFcccjkA4ypCM=</pin>
            <!-- GTS Root R1 (backup — different CA hierarchy) -->
            <pin digest="SHA-256">hxqRlPTu1bMS/0DITB1SSu0vd4u/8l8TjPgfaAp63Gc=</pin>
        </pin-set>
    </domain-config>
</network-security-config>
