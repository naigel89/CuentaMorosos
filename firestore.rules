rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper: user is authenticated ──────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    // ── Helper: user is event participant ──────────────────────────────
    // Checks ownerId, participantIds (modern), and memberIds (legacy).
    function isEventParticipant(eventDoc) {
      return request.auth.uid == eventDoc.data.ownerId
        || (eventDoc.data.participantIds is list
            && request.auth.uid in eventDoc.data.participantIds)
        || (eventDoc.data.memberIds is list
            && request.auth.uid in eventDoc.data.memberIds);
    }

    // ── Helper: user is event OWNER ────────────────────────────────────
    function isEventOwner(eventDoc) {
      return request.auth.uid == eventDoc.data.ownerId;
    }

    // ── Helper: user is event CONTRIBUTOR ──────────────────────────────
    // A contributor is a participant who is not the owner,
    // AND whose uid is in the contributorIds list.
    // Falls back to allowing non-owner participants for legacy events
    // that predate the contributorIds field.
    function isEventContributor(eventDoc) {
      return isEventParticipant(eventDoc) && !isEventOwner(eventDoc)
        && (!(eventDoc.data.contributorIds is list)
            || request.auth.uid in eventDoc.data.contributorIds);
    }

    // ── Helper: expense was created by the requesting user ─────────────
    function isExpenseCreator(eventDoc, expenseDoc) {
      return expenseDoc.data.createdByProfileId == request.auth.uid;
    }

    // ── Helper: expense was created by the requesting user (create) ────
    function isCreatingOwnExpense(eventDoc) {
      return request.resource.data.createdByProfileId == request.auth.uid;
    }

    // ── Users: self-access only ────────────────────────────────────────
    // Protects FCM tokens and private fields from cross-user access.
    match /users/{userId} {
      allow read, write: if isAuthenticated()
        && request.auth.uid == userId;
    }

    // ── Profiles ───────────────────────────────────────────────────────
    match /profiles/{profileId} {
      // Any authenticated user can read profiles (needed for
      // participant name resolution across shared events).
      allow read: if isAuthenticated();

      // Create: allowed when the new document's ownerId matches the
      // requester. This lets users create additional profiles (with
      // UUID document IDs) beyond their own identity profile.
      allow create: if isAuthenticated()
        && request.resource.data.ownerId == request.auth.uid;

      // Update/Delete: allowed when the requester is either the profile
      // document ID (own identity profile) or the profile's ownerId
      // (additional profiles this user created).
      allow update, delete: if isAuthenticated()
        && (request.auth.uid == profileId
            || resource.data.ownerId == request.auth.uid);

      // Custom names subcollection: per-viewer custom display names.
      match /customNames/{viewerId} {
        allow read, write: if isAuthenticated()
          && request.auth.uid == viewerId;
      }
    }

    // ── Events ─────────────────────────────────────────────────────────
    match /events/{eventId} {
      // Read: only participants can read event details.
      allow read: if isAuthenticated()
        && isEventParticipant(resource);

      // Create: only the owner specified in the new document.
      allow create: if isAuthenticated()
        && request.auth.uid == request.resource.data.ownerId;

      // Update: owner only. Prevents participants from modifying
      // event metadata, participants list, or lifecycle state.
      allow update: if isAuthenticated()
        && request.auth.uid == resource.data.ownerId;

      // Delete: owner only.
      allow delete: if isAuthenticated()
        && request.auth.uid == resource.data.ownerId;

      // ── Expenses subcollection ────────────────────────────────────
      match /expenses/{expenseId} {
        // Read: any event participant can read expenses.
        allow read: if isAuthenticated()
          && isEventParticipant(get(/databases/$(database)/documents/events/$(eventId)));

        // Create: OWNER creates any expense; CONTRIBUTOR creates own expense.
        // VIEWER (READER) cannot create expenses at all.
        // The createdByProfileId must match the requester's uid for non-OWNER.
        allow create: if isAuthenticated()
          && isEventParticipant(get(/databases/$(database)/documents/events/$(eventId)))
          && (isEventOwner(get(/databases/$(database)/documents/events/$(eventId)))
              || (isEventContributor(get(/databases/$(database)/documents/events/$(eventId)))
                  && isCreatingOwnExpense(get(/databases/$(database)/documents/events/$(eventId)))));

        // Update: OWNER updates any expense; CONTRIBUTOR updates own expense.
        allow update: if isAuthenticated()
          && isEventParticipant(get(/databases/$(database)/documents/events/$(eventId)))
          && (isEventOwner(get(/databases/$(database)/documents/events/$(eventId)))
              || (isEventContributor(get(/databases/$(database)/documents/events/$(eventId)))
                  && isExpenseCreator(
                       get(/databases/$(database)/documents/events/$(eventId)),
                       resource)));

        // Delete: OWNER deletes any expense; CONTRIBUTOR deletes own expense.
        allow delete: if isAuthenticated()
          && isEventParticipant(get(/databases/$(database)/documents/events/$(eventId)))
          && (isEventOwner(get(/databases/$(database)/documents/events/$(eventId)))
              || (isEventContributor(get(/databases/$(database)/documents/events/$(eventId)))
                  && isExpenseCreator(
                       get(/databases/$(database)/documents/events/$(eventId)),
                       resource)));

        // Audit subcollection: append-only expense mutation records.
        match /audit/{auditId} {
          allow read: if isAuthenticated()
            && isEventParticipant(get(/databases/$(database)/documents/events/$(eventId)));
          allow create: if isAuthenticated()
            && isEventParticipant(get(/databases/$(database)/documents/events/$(eventId)));
          allow update, delete: if false;
        }
      }

      // ── Debts subcollection ───────────────────────────────────────
      match /debts/{debtId} {
        // Debts are read by participants, written only by OWNER (via calculation).
        allow read: if isAuthenticated()
          && isEventParticipant(get(/databases/$(database)/documents/events/$(eventId)));

        allow write: if isAuthenticated()
          && isEventOwner(get(/databases/$(database)/documents/events/$(eventId)));
      }

      // ── Calculations subcollection ─────────────────────────────────
      match /calculations/{calcId} {
        // Calculation snapshots: read-only for event participants.
        // Created only by OWNER (server-side calculation or owner trigger).
        allow read: if isAuthenticated()
          && isEventParticipant(get(/databases/$(database)/documents/events/$(eventId)));

        allow create: if isAuthenticated()
          && isEventOwner(get(/databases/$(database)/documents/events/$(eventId)));

        allow update, delete: if false;
      }

      // ── Adjustments subcollection ──────────────────────────────────
      match /adjustments/{adjustmentId} {
        allow read: if isAuthenticated()
          && isEventParticipant(get(/databases/$(database)/documents/events/$(eventId)));

        // Only OWNER can create adjustments.
        allow create: if isAuthenticated()
          && isEventOwner(get(/databases/$(database)/documents/events/$(eventId)));

        allow update, delete: if false;
      }
    }

    // ── Invitations ────────────────────────────────────────────────────
    match /invitations/{invitationId} {
      // Only the sender or the invited person can read an invitation.
      allow read: if isAuthenticated()
        && (request.auth.uid == resource.data.invitedByUid
            || request.auth.token.email != null
            && request.auth.token.email == resource.data.invitedEmail);

      // Create: authenticated users can create invitations.
      allow create: if isAuthenticated()
        && request.auth.uid == request.resource.data.invitedByUid;

      // Update: only the invited person can accept/reject.
      allow update: if isAuthenticated()
        && (request.auth.uid == resource.data.invitedByUid
            || request.auth.token.email != null
            && request.auth.token.email == resource.data.invitedEmail);

      // Delete: sender only.
      allow delete: if isAuthenticated()
        && request.auth.uid == resource.data.invitedByUid;
    }

    // ── Notifications ──────────────────────────────────────────────────
    match /notifications/{uid} {
      // Notifications are organized per-user. Only the target user
      // can read or delete their own notifications.
      allow read, delete: if isAuthenticated()
        && request.auth.uid == uid;

      // Create: server-side (admin SDK) or the event owner for
      // invitation-accepted / calculation-completed notifications.
      allow create: if isAuthenticated();

      match /invitation-accepted/{notificationId} {
        allow read, write: if isAuthenticated()
          && request.auth.uid == uid;
      }

      match /calculation-completed/{notificationId} {
        allow read, write: if isAuthenticated()
          && request.auth.uid == uid;
      }
    }

    // ── Catch-all: deny everything else ────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
